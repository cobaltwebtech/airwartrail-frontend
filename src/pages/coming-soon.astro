---
import { getLiveCollection } from "astro:content";
import { Breadcrumb, BreadcrumbItem, BreadcrumbLink, BreadcrumbList, BreadcrumbSeparator } from "@/components/ui/breadcrumb";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { signTiptapImages } from "@/lib/sign-blog-images";
import { tiptapToHtml } from "@/lib/tiptap";

const { env } = Astro.locals.runtime;

const { entries: pages, error: pagesError } = await getLiveCollection("pageList", {
  sortBy: "publishedAt",
  sortOrder: "desc",
});

if (pagesError) {
  console.error("Failed to load pages:", pagesError.message);
}

const pagesWithSignedContent = await Promise.all(
  (pages ?? []).map(async (page) => {
    const signedImageMap = await signTiptapImages(page.data.pageContent, env, Astro.request);
    const htmlContent = tiptapToHtml(page.data.pageContent, { signedImageMap });
    return {
      slug: page.data.slug,
      title: page.data.title,
      htmlContent,
    };
  })
);

const pageTitle = `Coming Soon | Air War Trail`;
const structuredData = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	"@id": `https://www.airwartrail.com/coming-soon/`,
	url: `https://www.airwartrail.com/coming-soon/`,
	name: pageTitle,
	description:
		"Watch our curated collection of World War II documentaries, interviews, and historical films from the East Anglia Air War Project.",
	isPartOf: {
		"@type": "WebSite",
		url: "https://www.airwartrail.com/",
		name: "Air War Trail",
		description:
			"The documentary films, interviews, and images bring the voices alive from those who experienced World War II in an up close and personal way. The mission of Air War Trail is to bring you their stories, when freedom stood in the balance and a generation of the free made a difference in the world.",
	},
	inLanguage: "en-US",
};
---

<BaseLayout title={pageTitle} structuredData={structuredData}>
	<Breadcrumb className="mb-8">
		<BreadcrumbList>
			<BreadcrumbItem>
				<BreadcrumbLink href="/">Home</BreadcrumbLink>
			</BreadcrumbItem>
			<BreadcrumbSeparator />
			<BreadcrumbItem>Coming Soon</BreadcrumbItem>
		</BreadcrumbList>
	</Breadcrumb>

  <h1 class="text-4xl font-bold sm:text-5xl mb-8">Coming Soon</h1>
  <img src="https://www.airwartrail.com/cdn-cgi/imagedelivery/VtKsu_0w_bTlQSLpuy0EbA/cd18e408-09f5-468b-2b3f-8e64c8209300/mdnomark" alt="Air War Trail Logo" srcset="https://www.airwartrail.com/cdn-cgi/imagedelivery/VtKsu_0w_bTlQSLpuy0EbA/cd18e408-09f5-468b-2b3f-8e64c8209300/xsmnomark 400w, https://www.airwartrail.com/cdn-cgi/imagedelivery/VtKsu_0w_bTlQSLpuy0EbA/cd18e408-09f5-468b-2b3f-8e64c8209300/smnomark 640w, https://www.airwartrail.com/cdn-cgi/imagedelivery/VtKsu_0w_bTlQSLpuy0EbA/cd18e408-09f5-468b-2b3f-8e64c8209300/mdnomark 768w" sizes="(max-width: 768px) 100vw, 768px" class="mx-auto max-w-50" loading="lazy">

  {pagesWithSignedContent.length === 0 ? (
    <p class="text-lg text-muted-foreground">Check back soon for updates!</p>
  ) : (
    <section class="space-y-16 max-w-4xl mx-auto">
      {pagesWithSignedContent.map((page) => (
        <article key={page.slug} class="prose prose-lg dark:prose-invert max-w-none">
          <h2 class="text-3xl font-bold mb-4">{page.title}</h2>
          <Fragment set:html={page.htmlContent} />
        </article>
      ))}
    </section>
  )}
</BaseLayout>
