---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  Breadcrumb,
  BreadcrumbItem,
  BreadcrumbLink,
  BreadcrumbList,
  BreadcrumbPage,
  BreadcrumbSeparator,
} from "@/components/ui/breadcrumb";
import { TableOfContents } from "@/components/partials/TableOfContents";
import PremiumVideoWrapper from "@/components/episode/PremiumVideoWrapper.astro";
import FreeVideoWrapper from "@/components/episode/FreeVideoWrapper.astro";
import PremiumSlideshowWrapper from "@/components/episode/PremiumSlideshowWrapper.astro";

// Get the slug from params
const { slug } = Astro.params;
let episode;
let Content;
let headings;

try {
  // Handle the slug format, if it's an array join it
  const slugString = Array.isArray(slug) ? slug.join("/") : slug;

  // Get the episode in the collection
  const allEpisodes = await getCollection("episodes");
  episode = allEpisodes.find((ep) => ep.slug === slugString);

  if (!episode) throw new Error(`Episode not found: ${slugString}`);

  ({ Content, headings } = await episode.render());
} catch (error) {
  console.error("Error loading episode:", error);
  return Astro.redirect("/404");
}

// Format the date
const formattedDate = new Date(episode.data.date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title=`${episode.data.title} | Air War Trail`>
  <Breadcrumb className="my-8">
    <BreadcrumbList>
      <BreadcrumbItem>
        <BreadcrumbLink href="/">Home</BreadcrumbLink>
      </BreadcrumbItem>
      <BreadcrumbSeparator />
      <BreadcrumbItem>
        <BreadcrumbLink href="/episodes">All Episodes</BreadcrumbLink>
      </BreadcrumbItem>
      <BreadcrumbSeparator />
      <BreadcrumbItem>
        <BreadcrumbPage>{episode.data.title}</BreadcrumbPage>
      </BreadcrumbItem>
    </BreadcrumbList>
  </Breadcrumb>
  <div class="grid grid-cols-1 gap-8 md:grid-cols-5">
    <!-- Episode post content -->
    <article class="col-span-4 px-4 py-8">
      <header class="mb-8">
        <h1 class="mb-2 text-4xl font-bold">{episode.data.title}</h1>
        <div class="mb-4">
          <span>{formattedDate}</span>
          <span class="ml-4">By {episode.data.author}</span>
        </div>
        <div class="flex flex-wrap gap-2">
          {
            episode.data.tags.map((tag) => (
              <span class="bg-accent-1 text-secondary-foreground rounded-full px-3 py-1 text-sm">
                {tag}
              </span>
            ))
          }
        </div>
      </header>

      <div class="prose prose-lg dark:prose-invert max-w-max">
        <Content
          components={{
            PremiumVideo: PremiumVideoWrapper,
            PremiumSlideShow: PremiumSlideshowWrapper,
            FreeVideo: FreeVideoWrapper,
          }}
        />
      </div>
    </article>
    <!-- Table of Contents (sidebar)  -->
    <aside class="hidden flex-col gap-4 md:flex">
      <div
        class="sticky top-40 hidden self-start transition-all duration-200 md:block"
      >
        {
          headings && headings.length > 0 && (
            <TableOfContents
              client:load
              headings={headings.map((h) => ({
                ...h,
                subheadings: [],
              }))}
            />
          )
        }
      </div>
    </aside>
  </div>
</BaseLayout>
