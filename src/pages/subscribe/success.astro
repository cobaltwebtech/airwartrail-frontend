---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Button } from "@/components/ui/button";
import { CircleCheckBig } from "@lucide/astro";
import { TvMinimalPlay } from "@lucide/astro";
---

<BaseLayout title="Successfully Subscribed | Airwar Trail">
  <div class="container flex min-h-[80svh] items-center justify-center py-8">
    <div class="flex flex-col items-center gap-4 text-center">
      <div class="rounded-full bg-green-100 p-3">
        <CircleCheckBig class="size-16 text-green-500" />
      </div>
      <h1 class="text-4xl font-bold">Subscription Successful!</h1>
      <p class="text-muted-foreground">
        Thank you for subscribing to our premium plan. You now have access to
        all premium features.
      </p>
      <a href="/episodes" class="text-primary hover:underline">
        <Button>
          <TvMinimalPlay />
          View Episodes
        </Button>
      </a>
    </div>
  </div>
</BaseLayout>
