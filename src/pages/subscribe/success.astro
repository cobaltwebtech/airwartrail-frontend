---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Successfully Subscribed">
  <div
    class="container flex min-h-[calc(100vh-4rem)] items-center justify-center py-8"
  >
    <div class="flex flex-col items-center gap-4 text-center">
      <div class="rounded-full bg-green-100 p-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-8 w-8 text-green-500"
        >
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
      </div>
      <h1 class="text-3xl font-bold">Subscription Successful!</h1>
      <p class="text-muted-foreground">
        Thank you for subscribing to our premium plan. You now have access to
        all premium features.
      </p>
      <a href="/" class="text-primary hover:underline">Return to Home</a>
    </div>
  </div>
</BaseLayout>
