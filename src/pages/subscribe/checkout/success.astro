---
import { CircleCheckBig, TvMinimalPlay } from "@lucide/astro";
import { Button } from "@/components/ui/button";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { checkAuthOnly, redirectToLogin } from "@/lib/auth-check";

const { isAuthenticated } = await checkAuthOnly(Astro);

if (!isAuthenticated) {
	return redirectToLogin(Astro.url.pathname);
}
---

<BaseLayout title="Successfully Subscribed | Air War Trail">
  <section class="flex flex-col items-center gap-4 text-center">
    <div class="rounded-full bg-green-100 p-3">
      <CircleCheckBig class="size-16 text-green-500" />
    </div>
    <h1 class="text-4xl font-bold">Subscription Successful!</h1>
    <p class="text-muted-foreground">
      Thank you for subscribing to our premium plan. You now have access to
      all premium features.
    </p>
    <a href="/streaming/premium" class="text-primary hover:underline">
      <Button size="lg">
        <TvMinimalPlay />
        Start Watching Premium Content
      </Button>
    </a>
  </section>
</BaseLayout>
