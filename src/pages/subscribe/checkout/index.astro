---
import { CheckoutProcess } from "@/components/checkout/CheckoutProcess";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { checkAuthOnly, redirectToLogin } from "@/lib/auth-check";

const { isAuthenticated } = await checkAuthOnly(Astro);

if (!isAuthenticated) {
  return redirectToLogin(Astro.url.pathname);
}
---

<BaseLayout title="Checkout | Air War Trail">
  <h1 class="mb-8 text-center text-3xl font-bold">Checkout</h1>
  <CheckoutProcess client:load />
</BaseLayout>