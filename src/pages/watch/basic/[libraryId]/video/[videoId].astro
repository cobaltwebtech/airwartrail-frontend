---
import { Breadcrumb, BreadcrumbItem, BreadcrumbLink, BreadcrumbList, BreadcrumbSeparator } from "@/components/ui/breadcrumb";
import { RelatedVideos } from "@/components/video/RelatedVideos";
import { VideoPlayer } from "@/components/video/VideoPlayer";
import BaseLayout from "@/layouts/BaseLayout.astro";

// Extract parameters from the URL
const videoId = Astro.params.videoId ?? "";
const libraryId = Astro.params.libraryId ?? "";

// Check if URL has been modified to access premium content and redirect if so
const premiumLibraryId = import.meta.env.AWT_PREMIUM_LIBRARY_ID;
if (libraryId === premiumLibraryId) {
	return Astro.redirect("/subscribe");
}
const pageUrl = Astro.url.href;
const pageTitle = "Streaming | Air War Trail";

const structuredData = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	"@id": pageUrl,
	url: pageUrl,
	name: pageTitle,
	description:
		"Watch streaming content from Air War Trail. Detailed view for a single video with related information and resources.",
	isPartOf: {
		"@type": "WebSite",
		url: "https://www.airwartrail.com/",
		name: "Air War Trail",
	},
	inLanguage: "en-US",
};
---

<BaseLayout title={pageTitle} structuredData={structuredData}>
	<Breadcrumb className="mb-8">
		<BreadcrumbList>
			<BreadcrumbItem>
				<BreadcrumbLink href="/">Home</BreadcrumbLink>
			</BreadcrumbItem>
			<BreadcrumbSeparator />
			<BreadcrumbItem>
				<BreadcrumbLink href="/streaming/basic">Back to Free Content</BreadcrumbLink>
			</BreadcrumbItem>
		</BreadcrumbList>
	</Breadcrumb>
	<VideoPlayer
		client:load
		videoId={videoId}
		libraryId={libraryId}
		requiresSub={false}
	/>
	<RelatedVideos client:load isPremium={false} videoId={videoId} libraryId={libraryId} />
</BaseLayout>
