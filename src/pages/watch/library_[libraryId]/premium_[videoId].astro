---
import { Pricing } from "@/components/partials/Pricing";
import { Breadcrumb, BreadcrumbItem, BreadcrumbLink, BreadcrumbList, BreadcrumbSeparator } from "@/components/ui/breadcrumb";
import { RelatedVideos } from "@/components/video/RelatedVideos";
import { VideoPlayer } from "@/components/video/VideoPlayer";
import BaseLayout from "@/layouts/BaseLayout.astro";

// Check auth and subscription status via middleware
const { hasActiveSubscription } =
	Astro.locals.auth;

// Extract parameters from the URL
const videoId = Astro.params.videoId ?? "";
const libraryId = Astro.params.libraryId ?? "";
const pageUrl = Astro.url.href;
const pageTitle = "Streaming | Air War Trail";

const structuredData = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	"@id": pageUrl,
	url: pageUrl,
	name: pageTitle,
	description:
		"Watch streaming content from Air War Trail. Detailed view for a single video with related information and resources.",
	isPartOf: {
		"@type": "WebSite",
		url: "https://www.airwartrail.com/",
		name: "Air War Trail",
	},
	inLanguage: "en-US",
};
---

<BaseLayout title={pageTitle} structuredData={structuredData}>
	<Breadcrumb className="mb-8">
		<BreadcrumbList>
			<BreadcrumbItem>
				<BreadcrumbLink href="/">Home</BreadcrumbLink>
			</BreadcrumbItem>
			<BreadcrumbSeparator />
			<BreadcrumbItem>
				<BreadcrumbLink href="/streaming/premium">Premium Content</BreadcrumbLink>
			</BreadcrumbItem>
		</BreadcrumbList>
	</Breadcrumb>
	{hasActiveSubscription ? (
		<VideoPlayer
			client:load
			videoId={videoId}
			libraryId={libraryId}
			requiresSub={true}
		/>
		<RelatedVideos client:load isPremium={true} videoId={videoId} libraryId={libraryId} />
	) : (
		<Pricing />
	)}
</BaseLayout>
