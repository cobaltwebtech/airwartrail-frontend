---
import { Pricing } from "@/components/partials/Pricing";
import { AlbumDetail } from "@/components/photos/AlbumDetail";
import BaseLayout from "@/layouts/BaseLayout.astro";

// Check auth and subscription status via middleware
const { hasActiveSubscription } =
	Astro.locals.auth;

const { albumSlug } = Astro.params;

if (!albumSlug) {
	return Astro.redirect("/photos");
}

const pageTitle = "Photo Album | Air War Trail";
const structuredData = {
	"@context": "https://schema.org",
	"@type": "ImageGallery",
	"@id": `https://www.airwartrail.com/photos/${albumSlug}/`,
	url: `https://www.airwartrail.com/photos/${albumSlug}/`,
	name: pageTitle,
	description:
		"Browse historical photographs from the East Anglia Air War Project.",
	isPartOf: {
		"@type": "CollectionPage",
		url: "https://www.airwartrail.com/photos/",
		name: "Photographs | Air War Trail",
	},
	inLanguage: "en-US",
};
---

<BaseLayout title={pageTitle} structuredData={structuredData}>
	{hasActiveSubscription ? (
		<AlbumDetail client:load albumSlug={albumSlug} requiresSub={true} />
	) : (
		<Pricing />
	)}
</BaseLayout>
