---
export const prerender = true;

import { Button } from "@/components/ui/button";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { CircleX } from "@lucide/astro";
---

<BaseLayout title="Login Error | Airwar Trail">
  <div class="container flex min-h-[80svh] items-center justify-center py-8">
    <div class="flex flex-col items-center gap-4 text-center">
      <div
        class="flex size-16 flex-col items-center justify-center rounded-full bg-red-500 p-3"
      >
        <CircleX class="size-16 text-white" />
      </div>
      <h1 class="text-4xl font-bold">Login Error</h1>
      <p class="text-muted-foreground">
        An error occurred logging in. The password reset link is either invalid
        or expired.
      </p>
      <a href="/login/forget-password">
        <Button>Retry Password Reset</Button>
      </a>
    </div>
  </div>
</BaseLayout>
