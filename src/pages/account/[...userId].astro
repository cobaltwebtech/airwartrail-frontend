---
import { BillingInfo } from "@/components/user/BillingInfo";
import { UserCredentials } from "@/components/user/UserCredentials";
import { UserInfo } from "@/components/user/UserInfo";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="My Account | Air War Trail">
  <div class="container mx-auto">
    <h1 class="mb-4 text-3xl font-bold">Account Settings</h1>
    <div class="grid gap-6 md:grid-cols-2">
      <BillingInfo client:load />
      <UserInfo client:load />
      <UserCredentials client:load />
    </div>
  </div>
</BaseLayout>
