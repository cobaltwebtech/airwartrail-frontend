---

import { Pricing } from "@/components/partials/Pricing";
import { PlaylistsList } from "@/components/playlist/PlaylistsList";
import BaseLayout from "@/layouts/BaseLayout.astro";

// Check auth and subscription status via middleware
const { hasActiveSubscription } =
	Astro.locals.auth;

const videoLibraryId = import.meta.env.AWT_PREMIUM_LIBRARY_ID;
const pageTitle = "Playlists | Air War Trail";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://www.airwartrail.com/playlists/",
  url: "https://www.airwartrail.com/playlists/",
  name: "Playlists | Air War Trail",
  description:
    "In 2002 Military Historian and Producer/Director Vernon L. Williams established the East Anglia Air War Project with a mission to document the American air war against the German empire in the ETO.",
  isPartOf: {
    "@type": "WebSite",
    url: "https://www.airwartrail.com/",
    name: "Air War Trail",
    description:
      "The documentary films, interviews, and images bring the voices alive from those who experienced World War II in an up close and personal way. The mission of Air War Trail is to bring you their stories, when freedom stood in the balance and a generation of the free made a difference in the world.",
  },
  inLanguage: "en-US",
};
---

<BaseLayout title={pageTitle} structuredData={structuredData}>
  <h1 class="mb-2 text-center text-3xl font-bold">
    Playlists
  </h1>
  <p class="mb-8 text-center text-lg font-semibold">View our curated collection of films by playlists.</p>
  {hasActiveSubscription ? (
    <PlaylistsList client:load libraryId={videoLibraryId} />
  ) : (
    <Pricing />
  )}
</BaseLayout>
