---

import { getLiveCollection } from 'astro:content';
import { NotebookPen } from "@lucide/astro";
import { Breadcrumb, BreadcrumbItem, BreadcrumbLink, BreadcrumbList, BreadcrumbSeparator } from "@/components/ui/breadcrumb";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import BaseLayout from "@/layouts/BaseLayout.astro";

const { entries: posts, error } = await getLiveCollection('blogList', { 
  status: 'published',
  sortBy: 'publishedAt',
  sortOrder: 'desc',
});

if (error) {
  console.error('Failed to load blog posts:', error.message);
}

const pageTitle = "Blog Posts | Air War Trail";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://www.airwartrail.com/blog/",
  url: "https://www.airwartrail.com/blog/",
  name: "Blog Posts | Air War Trail",
  description:
    "In 2002 Military Historian and Producer/Director Vernon L. Williams established the East Anglia Air War Project with a mission to document the American air war against the German empire in the ETO.",
  isPartOf: {
    "@type": "WebSite",
    url: "https://www.airwartrail.com/",
    name: "Air War Trail",
    description:
      "The documentary films, interviews, and images bring the voices alive from those who experienced World War II in an up close and personal way. The mission of Air War Trail is to bring you their stories, when freedom stood in the balance and a generation of the free made a difference in the world.",
  },
  inLanguage: "en-US",
};
---

<BaseLayout title={pageTitle} structuredData={structuredData}>
  <Breadcrumb className="mb-8">
		<BreadcrumbList>
			<BreadcrumbItem>
				<BreadcrumbLink href="/">Home</BreadcrumbLink>
			</BreadcrumbItem>
			<BreadcrumbSeparator />
			<BreadcrumbItem>Blog Posts</BreadcrumbItem>
		</BreadcrumbList>
	</Breadcrumb>

  <h1 class="text-4xl font-bold sm:text-5xl">Blog Posts</h1>

  <div class="w-full grid sm:grid-cols-2 md:grid-cols-3 gap-8">
    {posts?.map(post => {
      const thumbnailUrl = post.data.featuredImageUrl?.replace(/\/md\/?$/, '/thumbnail');
      return (
      <a href={`/blog/${post.data.slug}`} class="group">
        <Card className="h-full bg-accent-6 hover:bg-accent-6/80 transition-colors duration-300 pt-0">
          {post.data.featuredImageUrl ? (
            <img
              src={thumbnailUrl}
              alt={post.data.featuredImageAlt || post.data.title}
              class="w-full aspect-3/2 object-cover rounded-t-lg"
            />
          ) : (
            <div class="w-full aspect-3/2 flex items-center justify-center bg-primary rounded-t-lg">
              <NotebookPen class="size-12" />
            </div>
          )}
          <CardHeader>
            <CardTitle>
            <h2 class="text-xl font-bold line-clamp-1 group-hover:underline">{post.data.title}</h2>
            </CardTitle>
            <CardDescription className="line-clamp-2">
              {post.data.shortDescription}
            </CardDescription>
          </CardHeader>
          <CardContent className="flex items-center justify-between">
            <p>Read Post <span class="inline-block group-hover:translate-x-1 transition-transform duration-300">&rarr;</span></p>
            <p class="text-sm text-muted-foreground">{post.data.readingTimeMinutes} min read</p>
          </CardContent>
        </Card>
      </a>
      );
    })}
  </div>
</BaseLayout>