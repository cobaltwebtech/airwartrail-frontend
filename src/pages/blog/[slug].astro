---

import { getLiveCollection } from 'astro:content';
import { Breadcrumb, BreadcrumbItem, BreadcrumbLink, BreadcrumbList, BreadcrumbSeparator } from "@/components/ui/breadcrumb";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { tiptapToHtml } from "@/lib/tiptap";

// Get the slug from the route parameter
const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/blog');
}

// Fetch blog posts from the Live Collection and find the one matching the slug
// We use getLiveCollection since getLiveEntry doesn't support filter by slug directly
const { entries, error } = await getLiveCollection('blog');

if (error) {
  console.error('Failed to load blog posts:', error.message);
  return Astro.redirect('/404');
}

// Find the post matching the slug (entries are indexed by slug as ID)
const post = entries?.find(entry => entry.id === slug);

// Return 404 if post not found
if (!post) {
  return Astro.redirect('/404');
}

const { 
  title, 
  shortDescription, 
  postContent, 
  featuredImageUrl, 
  featuredImageAlt,
  publishedAt, 
  author,
  readingTimeMinutes,
} = post.data;

const pageTitle = `${title} | Blog | Air War Trail`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `https://www.airwartrail.com/blog/${slug}/`,
  url: `https://www.airwartrail.com/blog/${slug}/`,
  headline: title,
  description: shortDescription,
  image: featuredImageUrl ? [featuredImageUrl] : undefined,
  datePublished: publishedAt,
  author: {
    "@type": "Person",
    name: author,
  },
  publisher: {
    "@type": "Organization",
    name: "Air War Trail",
    url: "https://www.airwartrail.com/",
  },
};

// Format the published date for display
const formattedDate = publishedAt 
  ? new Date(publishedAt).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<BaseLayout title={pageTitle} structuredData={structuredData}>
  <Breadcrumb className="mb-8">
		<BreadcrumbList>
			<BreadcrumbItem>
				<BreadcrumbLink href="/">Home</BreadcrumbLink>
			</BreadcrumbItem>
			<BreadcrumbSeparator />
			<BreadcrumbItem>
				<BreadcrumbLink href="/blog">Blog Posts</BreadcrumbLink>
			</BreadcrumbItem>
		</BreadcrumbList>
	</Breadcrumb>
  <article class="mx-auto max-w-3xl px-4 pb-12">
    <header class="mb-8">
      <h1 class="text-4xl font-bold sm:text-5xl">
        {title}
      </h1>
      {shortDescription && (
        <p class="mt-4 text-xl">
          {shortDescription}
        </p>
      )}
      <div class="mt-6 flex items-center gap-4 text-sm">
        <span>By {author}</span>
        {formattedDate && (
          <>
            <span>•</span>
            <time datetime={publishedAt ?? undefined}>{formattedDate}</time>
          </>
        )}
        {readingTimeMinutes && (
          <>
            <span>•</span>
            <span>{readingTimeMinutes} min read</span>
          </>
        )}
      </div>
    </header>

    <!-- Featured Image -->
    {featuredImageUrl && (
      <figure class="mb-8">
        <img 
          src={featuredImageUrl} 
          alt={featuredImageAlt || title} 
          class="w-full rounded-lg object-cover"
        />
      </figure>
    )}

    <!-- Post Content -->
    <div class="prose prose-lg dark:prose-invert">
      <Fragment set:html={tiptapToHtml(postContent)} />
    </div>
  </article>
</BaseLayout>
