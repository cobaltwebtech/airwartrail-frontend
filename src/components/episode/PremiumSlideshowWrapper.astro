---
// This Astro component is used to wrap the React components for premium content
import { PremiumSlideShow } from "@/components/episode/PremiumSlideShow";

const { slides, downloadUrl, ...props } = Astro.props;
---

<PremiumSlideShow
  client:visible
  slideData={slides}
  premiumImagesUrl={downloadUrl}
  {...props}
/>
