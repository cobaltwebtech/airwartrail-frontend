---
import { CircleX, SquareMenu } from "lucide-react";
import Logo from "@/assets/svgs/Airwar-Trail-Logo.svg";
import { AuthButtons } from "@/components/partials/AuthButtons";
import { ThemeToggle } from "@/components/partials/ThemeToggle";
import { Button } from "@/components/ui/button";

const { sessionData } = Astro.props;

interface NavItem {
  title: string;
  url: string;
}

const navItems: Array<NavItem> = [
  { title: "Streaming", url: "/streaming" },
  { title: "About", url: "/about" },
  { title: "Contact", url: "/contact" },
  { title: "Subscribe", url: "/subscribe" },
];
---

<header
  class="text-light bg-airwar-600 dark:bg-airwar-900 sticky inset-x-0 top-0 z-50 flex w-full flex-wrap py-2 lg:flex-nowrap lg:justify-start"
>
  <nav
    class="relative mx-auto flex w-full max-w-screen-xl basis-full flex-wrap items-center px-4 md:px-6 lg:grid lg:grid-cols-12 lg:px-8"
  >
    <div class="lg:col-span-4">
      {/* Logo */}
      <a
        class="flex items-center gap-x-2 lg:gap-x-4"
        href="/"
        aria-label="Airwar Trail Logo"
      >
        <Logo
          class="size-[80px] sm:size-[90px] md:size-[100px] lg:size-[120px]"
        />
        <span class="text-xl font-bold sm:text-2xl lg:text-4xl"
          >Air War Trail</span
        >
      </a>
    </div>

    {
      /* Container for buttons on Login, Sign Up, Theme Toggle, and Mobile menu */
    }
    <div
      class="ms-auto flex items-center gap-x-2 py-1 lg:order-3 lg:col-span-3 lg:gap-x-4 lg:ps-6"
    >
      {/* Login and Sign Up buttons */}
      <AuthButtons sessionData={sessionData} client:load />

      {/* Theme Toggle for dark/light mode */}
      <ThemeToggle client:load />

      <div class="lg:hidden">
        <Button
          type="button"
          size="icon"
          className="hs-collapse-toggle flex items-center justify-center"
          id="hs-navbar-hcail-collapse"
          aria-expanded="false"
          aria-controls="hs-navbar-hcail"
          aria-label="Toggle navigation"
          data-hs-collapse="#hs-navbar-hcail"
        >
          <SquareMenu className="hs-collapse-open:hidden size-4 shrink-0" />
          <CircleX className="hs-collapse-open:block hidden size-4 shrink-0" />
          <span class="sr-only">Toggle navigation</span>
        </Button>
      </div>
    </div>

    {/* Collapse */}
    <div
      id="hs-navbar-hcail"
      class="hs-collapse hidden grow basis-full overflow-hidden transition-all duration-300 lg:order-2 lg:col-span-5 lg:block lg:w-auto lg:basis-auto"
      aria-labelledby="hs-navbar-hcail-collapse"
    >
      {/* Menu Items */}
      <ul
        class="mt-5 ml-5 flex flex-col gap-x-0 gap-y-4 lg:m-0 lg:flex-row lg:items-center lg:justify-center lg:gap-x-7 lg:gap-y-0"
      >
        {
          navItems.map(({ title, url }) => (
            <li>
              <a
                class="flex items-center justify-start py-4 lg:justify-center"
                href={url}
              >
                <span class="text-md font-semibold text-nowrap">{title}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>
</header>
