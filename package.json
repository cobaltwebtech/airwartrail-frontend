{
  "name": "airwartrail-frontend",
  "type": "module",
  "version": "2.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "dev:cf": "astro build && pnpx wrangler dev",
    "format": "biome format --write",
    "lint": "biome lint",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 astro build",
    "deploy:cf": "astro build && pnpx wrangler deploy",
    "preview": "astro build && astro preview",
    "up:astro": "pnpx @astrojs/upgrade",
    "up:biome": "pnpm up @biomejs/biome@latest && pnpm biome migrate --write",
    "clean": "rm -rf dist node_modules pnpm-lock.yaml .astro",
    "cf-typegen": "wrangler types --env-interface Env"
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@astrojs/cloudflare": "13.1.2",
    "@astrojs/compiler-rs": "^0.1.6",
    "@astrojs/mdx": "5.0.2",
    "@astrojs/react": "5.0.1",
    "@astrojs/sitemap": "^3.7.1",
    "@better-auth/drizzle-adapter": "^1.5.5",
    "@better-auth/infra": "^0.1.12",
    "@better-auth/stripe": "^1.5.5",
    "@hookform/resolvers": "^5.2.2",
    "@lucide/astro": "^0.577.0",
    "@marsidev/react-turnstile": "^1.4.2",
    "@mux/mux-player-react": "^3.11.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^1.0.10",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.11.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.91.2",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@trpc/client": "^11.13.4",
    "@trpc/tanstack-react-query": "^11.13.4",
    "astro": "6.0.7",
    "better-auth": "1.5.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "embla-carousel": "9.0.0-rc01",
    "embla-carousel-autoplay": "9.0.0-rc01",
    "embla-carousel-react": "9.0.0-rc01",
    "lenis": "^1.3.19",
    "lucide-react": "^0.577.0",
    "preline": "^4.1.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "resend": "^6.9.4",
    "sonner": "^2.0.7",
    "stripe": "20.4.1",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@trpc/server": "^11.13.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.10",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "wrangler": "^4.75.0"
  }
}
