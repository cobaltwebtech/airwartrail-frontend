{
  "name": "airwartrail-frontend",
  "type": "module",
  "version": "0.56.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "dev:cf": "astro build && pnpx wrangler dev",
    "format": "biome format --write",
    "lint": "biome lint",
