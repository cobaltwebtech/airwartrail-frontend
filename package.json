    "lucide-react": "^1.8.0",
    "preline": "^4.1.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "resend": "^6.11.0",
    "sonner": "^2.0.7",
    "stripe": "22.0.1",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
